
#Область ОсновнойКод 

&НаСервере
Процедура ЗаполнитьНужноеНаСервере()

    // Очищаем таблицу
    ТаблицаВедомостей.Очистить();

    // Получаем данные по ведомостям
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ
        | Ведомость.Ссылка КАК Ссылка,
        | Ведомость.Дата КАК Дата,
        | МИНИМУМ(ВедомостьДоговоры.Договор.НачалоДействия) КАК МинДатаДоговора,
        | МАКСИМУМ(ВедомостьДоговоры.Договор.НачалоДействия) КАК МаксДатаДоговора
        |ИЗ
        | Документ.Ведомость КАК Ведомость
        | ЛЕВОЕ СОЕДИНЕНИЕ Документ.Ведомость.Договоры КАК ВедомостьДоговоры
        |  ПО ВедомостьДоговоры.Ссылка = Ведомость.Ссылка
        |СГРУППИРОВАТЬ ПО
        | Ведомость.Ссылка, Ведомость.Дата
        |УПОРЯДОЧИТЬ ПО
        | Ведомость.Дата ВОЗР";

    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();

    ПодошлоПоУсловию = 0;

    Пока Выборка.Следующий() Цикл
	
        Дата = Выборка.Дата;
        Если Дата = ТекущаяДата() Тогда
            Продолжить;
        КонецЕсли;
  
        // Получаем первый активный договор
        ДатаПервогоАктивногоДоговора = ПолучитьПервыйАктивныйДоговор(Выборка.Ссылка);
        
        Если ДатаПервогоАктивногоДоговора = Неопределено Тогда
            Продолжить;
        КонецЕсли;

        МинДата = Выборка.МинДатаДоговора;
        МаксДата = Выборка.МаксДатаДоговора;

        // Сравнение по условию
        Подходит = Ложь;
        Если ДатаНачалаДействияАктивногоДоговора = "РавенМинимальнойДате" Тогда
            Подходит = (ДатаПервогоАктивногоДоговора = МинДата);
        ИначеЕсли ДатаНачалаДействияАктивногоДоговора = "НеРавенМинимальнойДате" Тогда
            Подходит = (ДатаПервогоАктивногоДоговора <> МинДата);
        ИначеЕсли ДатаНачалаДействияАктивногоДоговора = "РавенМаксимальнойДате" Тогда
            Подходит = (ДатаПервогоАктивногоДоговора = МаксДата);
        ИначеЕсли ДатаНачалаДействияАктивногоДоговора = "НеРавенМаксимальнойДате" Тогда
            Подходит = (ДатаПервогоАктивногоДоговора <> МаксДата);
        КонецЕсли;

        Если Подходит Тогда
            ПодошлоПоУсловию = ПодошлоПоУсловию + 1;
            НоваяСтрока = ТаблицаВедомостей.Добавить();
            НоваяСтрока.Ведомость = Выборка.Ссылка;
        КонецЕсли;

    КонецЦикла;

    //ВЫВОДИМ В ТАБЛИЧНЫЙ ДОКУМЕНТ С РАСКРАСКОЙ
    ВывестиТаблицуВТабличныйДокумент();

    
КонецПроцедуры

&НаСервере
Процедура УдалитьЛишнееНаСервере()
	
	// Строка для сбора номеров удаленных документов
	НомераУдаленных = "";
    Счетчик = 0;
    
    // Перебираем все строки в таблице с конца
    НомерСтроки = ТаблицаВедомостей.Количество() - 1;
    Пока НомерСтроки >= 0 Цикл
        
        ТекущаяСтрока = ТаблицаВедомостей[НомерСтроки];
        
        // Считаем сколько договоров у этой ведомости
        Запрос = Новый Запрос;
        Запрос.Текст = 
            "ВЫБРАТЬ
            |	КОЛИЧЕСТВО(ВедомостьДоговоры.Договор) КАК КоличествоДоговоров,
            |	ВедомостьДоговоры.Ссылка.Номер КАК Номер
            |ИЗ
            |	Документ.Ведомость.Договоры КАК ВедомостьДоговоры
            |ГДЕ
            |	ВедомостьДоговоры.Ссылка = &Ссылка
            |
            |СГРУППИРОВАТЬ ПО
            |	ВедомостьДоговоры.Ссылка.Номер";
        Запрос.УстановитьПараметр("Ссылка", ТекущаяСтрока.Ведомость);
        
        Результат = Запрос.Выполнить();
        Выборка = Результат.Выбрать();
        Выборка.Следующий();
        КоличествоДоговоров = Выборка.КоличествоДоговоров;
        
        // Проверяем, четное ли количество
        Если КоличествоДоговоров % 2 = 0 Тогда
            
            // Получаем номер ведомости
            НомерДокумента = Выборка.Номер; // Просто берем все представление
            
            // Добавляем номер в общую строку
            Если Счетчик > 0 Тогда
                НомераУдаленных = НомераУдаленных + ", ";
            КонецЕсли;
            НомераУдаленных = НомераУдаленных + НомерДокумента;
            
            // Увеличиваем счетчик
            Счетчик = Счетчик + 1;
            
            // Удаляем строку из таблицы
            ТаблицаВедомостей.Удалить(ТекущаяСтрока);
            
        КонецЕсли;
        
        // Переходим к предыдущей строке
        НомерСтроки = НомерСтроки - 1;
        
    КонецЦикла;
    
    // Сообщаем пользователю результат
    Если Счетчик > 0 Тогда
        Сообщить("Удалено документов: " + Счетчик + " (" + НомераУдаленных + ").");
    Иначе
        Сообщить("Нет документов с четным количеством договоров.");
    КонецЕсли;
    
    // Перерисовываем таблицу
    ВывестиТаблицуВТабличныйДокумент();
КонецПроцедуры

#КонецОбласти

#Область ВпомогательныеПроцедурыИФункции

&НаСервере
Функция ПолучитьПервыйАктивныйДоговор(СсылкаНаВедомость)
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        | ВедомостьДоговоры.Договор.НачалоДействия КАК НачалоДействия
        |ИЗ
        | Документ.Ведомость.Договоры КАК ВедомостьДоговоры
        |ГДЕ
        | ВедомостьДоговоры.Ссылка = &Ссылка
        | И ВедомостьДоговоры.Договор.Активен = ИСТИНА";
    
    Запрос.УстановитьПараметр("Ссылка", СсылкаНаВедомость);
    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();
    
    Если Выборка.Следующий() Тогда
        Возврат Выборка.НачалоДействия;
    КонецЕсли;
    
    Возврат Неопределено;
    
КонецФункции

&НаСервере
Функция ПолучитьПоследнийСтатус(Ведомость)
	
	Запрос = Новый Запрос;
    Запрос.Текст = 
      "ВЫБРАТЬ ПЕРВЫЕ 1
      | ИсторияСтатусовДокументов.Статус КАК Статус
      |ИЗ
      | РегистрСведений.ИсторияСтатусовДокументов КАК ИсторияСтатусовДокументов
      |ГДЕ
      | ИсторияСтатусовДокументов.Документ = &Документ
      |УПОРЯДОЧИТЬ ПО
      | ИсторияСтатусовДокументов.ДатаЗаписи УБЫВ"; 
    
    Запрос.УстановитьПараметр("Документ", Ведомость);
    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();
    
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Статус;
    Иначе
        Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ВывестиТаблицуВТабличныйДокумент()
    
   // Создаем табличный документ
    ТабДок = Новый ТабличныйДокумент;
    ТабДок.Очистить();
    
    // Выводим шапку с границами и пробелами
    ОбластьШапки = ТабДок.Область(1, 1, 1, 1);
    ОбластьШапки.Текст = "Ведомость";
    ОбластьШапки.Шрифт = Новый Шрифт(, , Истина);
    ОбластьШапки.ГраницаСнизу = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
    ОбластьШапки.ГраницаСверху = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
    ОбластьШапки.ГраницаСлева = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
    ОбластьШапки.ГраницаСправа = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
    
    // Выводим строки
    НомерСтроки = 2;
    Для Каждого Строка Из ТаблицаВедомостей Цикл
        
        ПоследнийСтатус = ПолучитьПоследнийСтатус(Строка.Ведомость);
        ОбластьСтроки = ТабДок.Область(НомерСтроки, 1, НомерСтроки, 1);
        
        // Текст
		ОбластьСтроки.Текст = Строка(Строка.Ведомость);
		ОбластьСтроки.РастягиватьПоГоризонтали = Истина;
        
        // Границы
        ОбластьСтроки.ГраницаСнизу = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
        ОбластьСтроки.ГраницаСверху = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
        ОбластьСтроки.ГраницаСлева = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
        ОбластьСтроки.ГраницаСправа = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
        
        // Закрашиваем если Акцептован
        Если ПоследнийСтатус = Перечисления.СтатусыДокументов.Акцептован Тогда
            ОбластьСтроки.ЦветФона = WebЦвета.БледноЗеленый;
        КонецЕсли;
        
        НомерСтроки = НомерСтроки + 1;
        
    КонецЦикла;
    
    // Показываем результат
    ЭтаФорма.РезультатТабДок = ТабДок;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКоманд

&НаКлиенте
Процедура ЗаполнитьНужное(Команда)
    ЗаполнитьНужноеНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЛишнее(Команда)
	УдалитьЛишнееНаСервере();
КонецПроцедуры

#КонецОбласти
